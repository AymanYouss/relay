{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Relay — Gateway Overview",
  "uid": "relay-overview",
  "tags": ["relay", "llm", "gateway"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Request rate",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "targets": [
        { "expr": "sum(rate(relay_requests_total[5m]))", "legendFormat": "req/s" }
      ]
    },
    {
      "type": "stat",
      "title": "Cache hit rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.2 },
            { "color": "green", "value": 0.4 }
          ] }
        }
      },
      "targets": [
        { "expr": "sum(rate(relay_cache_lookups_total{result=\"hit\"}[10m])) / clamp_min(sum(rate(relay_cache_lookups_total[10m])), 1e-9)", "legendFormat": "hit rate" }
      ]
    },
    {
      "type": "stat",
      "title": "p99 latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(relay_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "stat",
      "title": "Spend (per hour)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } },
      "targets": [
        { "expr": "sum(rate(relay_cost_usd_total[1h])) * 3600", "legendFormat": "$/h" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests by model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
      "targets": [
        { "expr": "sum(rate(relay_requests_total[5m])) by (model)", "legendFormat": "{{model}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(relay_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(relay_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(relay_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache lookups",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "targets": [
        { "expr": "sum(rate(relay_cache_lookups_total[5m])) by (result)", "legendFormat": "{{result}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens per second",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "sum(rate(relay_tokens_total[5m])) by (direction)", "legendFormat": "{{direction}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Spend rate by model",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        { "expr": "sum(rate(relay_cost_usd_total[10m])) by (model) * 3600", "legendFormat": "{{model}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Retries and failovers",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(relay_retries_total[5m]))", "legendFormat": "retries" },
        { "expr": "sum(rate(relay_failovers_total[5m]))", "legendFormat": "failovers" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Upstream latency by provider",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(relay_upstream_duration_seconds_bucket[5m])) by (le, provider))", "legendFormat": "{{provider}} p95" }
      ]
    }
  ]
}
